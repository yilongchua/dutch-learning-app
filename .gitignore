# Project-specific gitignore for thesystem

# OS generated files
.DS_Store
.DS_Store?
._*

# IDEs and editors
.vscode/
.idea/
*.swp
*.swo
*~

# Environment variables
.env
.env.local
.env.*.local
*.env

# Node.js
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.eslintcache

# Frontend build
frontend/build/
frontend/dist/
frontend/out/
frontend/.react-router/
frontend/.output/
frontend/.vercel/

# Python
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv
venv/
ENV/
env.bak/
venv.bak/
.pytest_cache/
.coverage
.cache

# Data and Logs
*.log
data/images/*
!data/images/.gitkeep
data/audio/*
!data/audio/.gitkeep
data/app/*
!data/app/.gitkeep

# zrok
zrok/**/*.log
fastapi_env/